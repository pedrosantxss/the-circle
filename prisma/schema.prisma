generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Application {
  id        String   @id @default(cuid())
  fullName  String
  age       Int
  city      String
  email     String   @unique
  whatsapp  String
  instagram String
  goals     String
  project   String?
  status    Status   @default(NEW)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Status {
  NEW
  UNDER_REVIEW
  APPROVED
  REJECTED
}
