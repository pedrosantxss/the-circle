generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Application {
  id                   String   @id @default(cuid())
  fullName             String
  age                  Int
  city                 String
  email                String   @unique
  whatsapp             String
  instagram            String
  focus                String
  whyJoin              String
  goal12months         String
  hasProject           Boolean
  projectDescription   String?
  desiredConnections   String
  contribution         String
  whySelected          String
  activeParticipation  Boolean
  dreamConversation    String
  status               Status   @default(NEW)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

enum Status {
  NEW
  UNDER_REVIEW
  APPROVED
  REJECTED
}
